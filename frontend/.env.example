# EmailJS — required for the contact form to send emails directly
# Get these from https://www.emailjs.com → your service/template/account
VITE_EMAILJS_SERVICE_ID=service_khn51qm
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# App encryption key — used internally
VITE_APP_ENCRYPT_KEY=your_encrypt_key_here
